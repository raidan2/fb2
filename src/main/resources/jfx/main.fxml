<!--<?import javafx.scene.web.WebView?>-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeTableColumn?>
<?import javafx.scene.control.TreeTableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<VBox fx:id="mainPage" prefHeight="600.0" prefWidth="1500.0" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1">
    <MenuBar VBox.vgrow="NEVER">
        <Menu mnemonicParsing="false" text="File">
            <MenuItem fx:id="menuCreateLibrary" mnemonicParsing="false" text="Create new Library..."
                      visible="false"/>
            <MenuItem fx:id="menuOpenLibrary" mnemonicParsing="false" text="Open Library..."
                      visible="false"/>
            <Menu fx:id="menuRemoveRecent" mnemonicParsing="false" text="Open Recent" visible="false"/>
            <MenuItem fx:id="menuCloseLibrary" mnemonicParsing="false" text="Close Library"
                      visible="false"/>
            <SeparatorMenuItem mnemonicParsing="false" visible="false"/>
            <MenuItem fx:id="menuPreferences" mnemonicParsing="false" text="Preferences…" visible="false"/>
            <SeparatorMenuItem mnemonicParsing="false" visible="false"/>
            <MenuItem fx:id="menuQuit" mnemonicParsing="false" text="Quit"/>
        </Menu>
        <Menu mnemonicParsing="false" text="Help">
            <MenuItem fx:id="menuAbout" mnemonicParsing="false" text="About"/>
        </Menu>
    </MenuBar>
    <SplitPane dividerPositions="0.25, 0.80" focusTraversable="true" VBox.vgrow="ALWAYS">
        <VBox>
            <HBox VBox.vgrow="NEVER">
                <TextField fx:id="fieldSearch" alignment="TOP_LEFT" promptText="Enter Author or Book"
                           HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="comboLang" prefWidth="75.0" visibleRowCount="20"/>
            </HBox>
            <ListView fx:id="listAuthors" VBox.vgrow="ALWAYS">
                <contextMenu>
                    <ContextMenu fx:id="contextMenuAuthors">
                        <items>
                            <MenuItem fx:id="contextAuthorsMenuItemExportAllBooks" mnemonicParsing="false"
                                      text="Export all books"/>
                        </items>
                    </ContextMenu>
                </contextMenu>
            </ListView>
        </VBox>
        <AnchorPane>
            <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">
                <TreeTableView fx:id="treeBooks" VBox.vgrow="ALWAYS">
                    <columns>
                        <TreeTableColumn fx:id="columnBookId" prefWidth="450.0" text="Title"/>
                        <TreeTableColumn fx:id="columnBookSeries" prefWidth="75.0" text="Series"/>
                        <TreeTableColumn fx:id="columnBookSize" prefWidth="75.0" text="Size"/>
                        <TreeTableColumn fx:id="columnBookLang" prefWidth="75.0" text="Language"/>
                        <TreeTableColumn fx:id="columnBookDate" prefWidth="90.0" text="Date"/>
                        <TreeTableColumn fx:id="columnBookGenre" prefWidth="75.0" text="Genre"
                                         visible="false"/>
                    </columns>
                    <contextMenu>
                        <ContextMenu fx:id="contextMenuBooks">
                            <items>
                                <MenuItem fx:id="contextBooksMenuItemOpenBook" mnemonicParsing="false"
                                          text="Open book"/>
                                <SeparatorMenuItem mnemonicParsing="false"/>
                                <MenuItem fx:id="contextBooksMenuItemExportSelectedBooks"
                                          mnemonicParsing="false" text="Export selected books"/>
                                <MenuItem fx:id="contextBooksMenuItemExportAllBooks"
                                          mnemonicParsing="false" text="Export all books"/>
                            </items>
                        </ContextMenu>
                    </contextMenu>
                </TreeTableView>
            </VBox>
        </AnchorPane>
        <AnchorPane>
            <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">
                <HBox alignment="CENTER" prefHeight="200.0">
                    <ImageView fx:id="imageBook" fitHeight="200.0" fitWidth="200.0"
                               pickOnBounds="true" preserveRatio="true"/>
                </HBox>
                <TextArea fx:id="viewDescription" editable="false" wrapText="true" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </VBox.margin>
                </TextArea>
            </VBox>
        </AnchorPane>
    </SplitPane>
    <HBox id="HBox" alignment="CENTER_LEFT" spacing="5.0" VBox.vgrow="NEVER">
        <padding>
            <Insets bottom="3.0" left="3.0" right="3.0" top="3.0"/>
        </padding>
        <Label fx:id="labelDatabase">
            <font>
                <Font size="11.0" fx:id="x31"/>
            </font>
            <textFill>
                <Color red="0.625" green="0.625" blue="0.625" fx:id="x41"/>
            </textFill>
        </Label>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelStatus" text="Loading..." HBox.hgrow="NEVER">
            <font>
                <Font size="11.0" fx:id="x3"/>
            </font>
        </Label>
    </HBox>
</VBox>
