<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%date [%thread] %-5level %logger{36} -%kvp- %msg%n</pattern>
        </encoder>
    </appender>
    <logger name="ru.raidan.books" level="DEBUG"/>
    <root level="info">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>